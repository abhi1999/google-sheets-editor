# ============================================
# Google OAuth (NextAuth)
# ============================================
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_use_openssl_rand_base64_32

# ============================================
# Google Service Account (Sheets API)
# ============================================
# Option A: JSON string of service account key
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Option B: Path to service account key file (alternative to Option A)
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json

# ============================================
# Google Sheets Configuration
# ============================================
SHEET_ID=your_google_sheet_id_here
SHEET_RANGE=Sheet1!A1:Z1000
AUDIT_SHEET_NAME=AuditLog

# Comma-separated list of editable column headers (must match your sheet headers exactly)
EDITABLE_COLUMNS=Status,Notes,Assigned To,Score

# ============================================
# Permission Model
# ============================================
# Option A: Comma-separated editor emails
EDITOR_EMAILS=admin@example.com,coach@example.com,manager@club.com

# Option B: Path to JSON config file with editors list
# EDITORS_CONFIG_PATH=./editors.json

# ============================================
# App Configuration
# ============================================
PAGE_SIZE=25
AUTO_SAVE=false
